---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Your Name" description="Get in touch." activePage="contact">

  <div class="page-header">
    <p class="page-header-label">Say hello</p>
    <h1>Contact</h1>
    <p>Whether it's a project, a question, or just a hello — my inbox is open.</p>
  </div>

  <div class="contact-wrap">
    <aside class="contact-sidebar">
      <h2>Let's<br/><em>connect.</em></h2>
      <p>
        I'm always happy to hear from curious people. Response time is usually
        within a couple of days.
      </p>

      <div class="contact-channels">
        <a href="mailto:mail@everestkc.org" class="contact-channel">
          <span class="contact-channel-icon" style="font-size:1.3rem">✉</span>
          <div>
            <p class="contact-channel-label">Email</p>
            <p class="contact-channel-value">mail@everestkc.org</p>
          </div>
        </a>
        <a href="https://twitter.com/babueverest" target="_blank" rel="noopener" class="contact-channel">
          <span class="contact-channel-icon">𝕏</span>
          <div>
            <p class="contact-channel-label">Twitter / X</p>
            <p class="contact-channel-value">@babueverest</p>
          </div>
        </a>
        <a href="https://linkedin.com/in/babueverest" target="_blank" rel="noopener" class="contact-channel">
          <span class="contact-channel-icon">in</span>
          <div>
            <p class="contact-channel-label">LinkedIn</p>
            <p class="contact-channel-value">babueverest</p>
          </div>
        </a>
        <a href="https://github.com/everestkc" target="_blank" rel="noopener" class="contact-channel">
          <span class="contact-channel-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          </span>
          <div>
            <p class="contact-channel-label">GitHub</p>
            <p class="contact-channel-value">everestkc</p>
          </div>
        </a>
      </div>
    </aside>

    <form class="contact-form" id="contact-form">
      <!-- Web3Forms: get your free access key at https://web3forms.com -->
      <input type="hidden" name="access_key" value="f1aecd32-bdff-42a7-b0f3-644fbbb6e8e5" />
      <input type="hidden" name="to" value="everestkc@everestkc.com.np" />
      <input type="hidden" name="subject" value="New message from your website" />
      <input type="checkbox" name="botcheck" style="display:none" />

      <div class="form-group">
        <label class="form-label" for="name">Name</label>
        <input class="form-input" type="text" id="name" name="name" placeholder="Your full name" required />
      </div>
      <div class="form-group">
        <label class="form-label" for="email">Email</label>
        <input class="form-input" type="email" id="email" name="email" placeholder="your@email.com" required />
      </div>
      <div class="form-group">
        <label class="form-label" for="subject">Subject</label>
        <input class="form-input" type="text" id="subject" name="subject" placeholder="What's this about?" />
      </div>
      <div class="form-group">
        <label class="form-label" for="message">Message</label>
        <textarea class="form-textarea" id="message" name="message" placeholder="Tell me what's on your mind…" required></textarea>
      </div>
      <div>
        <button type="submit" class="btn btn-primary" id="submit-btn">Send message →</button>
        <p id="form-status" style="margin-top:1rem; font-size:0.82rem; color:var(--text-muted);"></p>
      </div>
    </form>
  </div>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending…';
    btn.disabled = true;

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      const data = await res.json();
      if (res.ok && data.success) {
        form.reset();
        if (status) status.textContent = '✓ Message sent! I\'ll get back to you soon.';
        btn.textContent = 'Sent!';
      } else {
        throw new Error(data.message);
      }
    } catch {
      if (status) {
        status.textContent = 'Something went wrong — please email me directly at everestkc@everestkc.com.np';
        status.style.color = 'var(--text-primary)';
      }
      btn.textContent = 'Send message →';
      btn.disabled = false;
    }
  });
</script>
