---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found | The Everest's Terminal" description="This page doesn't exist.">

  <div class="notfound-wrap">

    <div class="notfound-content">

      <p class="notfound-eyebrow">404 · Not Found</p>

      <h1 class="notfound-heading">
        <em>Lost in the</em><br />
        filesystem.
      </h1>

      <p class="notfound-desc">
        The page you're looking for doesn't exist, was moved, or<br class="br-hide" />
        was never deployed to production.
      </p>

      <!-- Terminal block -->
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot terminal-dot-red"></span>
          <span class="terminal-dot terminal-dot-yellow"></span>
          <span class="terminal-dot terminal-dot-green"></span>
          <span class="terminal-title">zsh — everest@terminal</span>
        </div>
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="terminal-prompt">everest@terminal:~$</span>
            <span class="terminal-cmd"> curl https://everestkc.org<span id="typed-path"></span></span>
          </div>
          <div class="terminal-output">
            <span class="terminal-comment">&lt; HTTP/2 <strong>404</strong></span><br />
            <span class="terminal-comment">&lt; content-type: text/html</span><br />
            <span class="terminal-error">curl: (22) The requested URL returned error: 404</span>
          </div>
          <div class="terminal-line terminal-line-last">
            <span class="terminal-prompt">everest@terminal:~$</span>
            <span class="terminal-cmd"> <span class="terminal-cursor">█</span></span>
          </div>
        </div>
      </div>

      <div class="notfound-actions">
        <a href="/" class="btn btn-primary">← Back to home</a>
        <a href="/blog" class="btn btn-outline">Browse the blog</a>
      </div>

    </div>

    <!-- Decorative exit code badge -->
    <div class="exit-badge" aria-hidden="true">
      <span class="exit-label">exit code</span>
      <strong class="exit-code">404</strong>
    </div>

  </div>

</Layout>

<style>
  .notfound-wrap {
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem 6rem;
    position: relative;
    overflow: hidden;
  }

.notfound-content {
    position: relative;
    z-index: 1;
    max-width: 640px;
    width: 100%;
    animation: fadeUp 0.65s ease both;
  }

  /* ── Eyebrow ── */
  .notfound-eyebrow {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .notfound-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--text-muted);
    flex-shrink: 0;
  }

  /* ── Heading ── */
  .notfound-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .notfound-heading em {
    font-style: italic;
    font-weight: 400;
    color: var(--text-secondary);
  }

  /* ── Description ── */
  .notfound-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.78;
    margin-bottom: 2.25rem;
  }

  .br-hide { display: block; }

  /* ── Terminal ── */
  .terminal {
    background: #0e0e0e;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 2.25rem;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.22);
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
  }

  /* titlebar */
  .terminal-bar {
    background: #1a1a1a;
    border-bottom: 1px solid #2a2a2a;
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .terminal-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .terminal-dot-red    { background: #ff5f57; }
  .terminal-dot-yellow { background: #febc2e; }
  .terminal-dot-green  { background: #28c840; }

  .terminal-title {
    font-size: 0.7rem;
    color: #666;
    margin-left: 0.5rem;
    letter-spacing: 0.04em;
  }

  /* body */
  .terminal-body {
    padding: 1.1rem 1.35rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .terminal-line {
    display: flex;
    align-items: baseline;
    gap: 0;
    font-size: 0.825rem;
    line-height: 1.7;
    flex-wrap: wrap;
  }

  .terminal-line-last { margin-top: 0.5rem; }

  .terminal-prompt {
    color: #3fa66f;
    font-weight: 600;
    white-space: nowrap;
  }

  .terminal-cmd {
    color: #e0e0e0;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .terminal-output {
    font-size: 0.8rem;
    line-height: 1.85;
    padding: 0.4rem 0 0.1rem 1.5rem;
  }

  .terminal-comment { color: #666; }

  .terminal-error { color: #ff5f57; }

  /* blinking cursor */
  .terminal-cursor {
    color: #e0e0e0;
    animation: blink 1.1s step-end infinite;
    font-size: 0.75rem;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── Actions ── */
  .notfound-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Exit code badge ── */
  .exit-badge {
    position: absolute;
    bottom: 3rem;
    right: 3rem;
    text-align: right;
    user-select: none;
    pointer-events: none;
    opacity: 0.06;
  }

  .exit-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .exit-code {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(6rem, 14vw, 11rem);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--text-primary);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .br-hide  { display: none; }
    .exit-badge { display: none; }
    .terminal-body { padding: 0.9rem 1rem 1rem; }
    .terminal-line { font-size: 0.75rem; }
    .terminal-output { font-size: 0.72rem; }
  }
</style>

<script>
  // Type the current path into the terminal command
  const el = document.getElementById('typed-path');
  if (el) {
    const path = window.location.pathname;
    let i = 0;
    const interval = setInterval(() => {
      el.textContent = path.slice(0, ++i);
      if (i >= path.length) clearInterval(interval);
    }, 55);
  }
</script>
